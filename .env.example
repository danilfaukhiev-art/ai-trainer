# ===========================================
# AI PERSONAL TRAINER — Environment Config
# ===========================================

# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_WEBHOOK_URL=https://your-domain.com/webhook/telegram
TELEGRAM_WEBHOOK_SECRET=generate_random_32_chars

# Database
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/ai_trainer
DATABASE_URL_SYNC=postgresql://postgres:password@localhost:5432/ai_trainer

# Redis
REDIS_URL=redis://localhost:6379/0

# OpenAI
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o
OPENAI_VISION_MODEL=gpt-4o

# S3 / Object Storage
S3_ENDPOINT_URL=https://s3.amazonaws.com
S3_ACCESS_KEY=your_access_key
S3_SECRET_KEY=your_secret_key
S3_BUCKET_NAME=ai-trainer-storage
S3_REGION=us-east-1

# App
APP_SECRET_KEY=generate_random_64_chars
APP_ENV=development
APP_PORT=8000
CORS_ORIGINS=http://localhost:5173,https://your-miniapp-domain.com

# Subscription
TRIAL_DAYS=7
FREE_AI_MESSAGES_PER_DAY=3
